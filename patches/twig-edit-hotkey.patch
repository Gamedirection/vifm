+    def action_edit(self) -> None:
+        """Open the current file in an external editor and reload it on return."""
+        editor = self._get_editor_command()
+        if not editor:
+            self.notify("No editor found in $VISUAL, $EDITOR, or common fallbacks.", severity="error")
+            return
+
+        try:
+            with self.suspend():
+                subprocess.run([*editor, self.file_path], check=False)
+        except Exception as e:
+            self.notify(f"Failed to launch editor: {e}", severity="error")
+            return
+
+        self.force_rebuild = True
+        self.push_screen(LoadingScreen(message=f"Reloading {os.path.basename(self.file_path)}..."))
