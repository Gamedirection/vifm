+    def _get_editor_command(self) -> list[str] | None:
+        """Resolve the editor command from the environment or common fallbacks."""
+        for env_var in ("VISUAL", "EDITOR"):
+            value = os.environ.get(env_var, "").strip()
+            if value:
+                command = shlex.split(value)
+                if command and shutil.which(command[0]):
+                    return command
+
+        for fallback in ("lvim", "nvim", "vim", "vi"):
+            if shutil.which(fallback):
+                return [fallback]
+
+        return None
+
